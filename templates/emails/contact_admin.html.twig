<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: Arial, sans-serif; font-size: 14px; color: #333; }
        .header { background: #1A237E; color: white; padding: 20px; text-align: center; }
        .content { padding: 30px; }
        .field { margin-bottom: 16px; }
        .label { font-weight: bold; color: #555; font-size: 12px;
                 text-transform: uppercase; letter-spacing: 1px; }
        .value { margin-top: 4px; padding: 10px;
                 background: #f5f5f5; border-radius: 4px; }
        .footer { text-align: center; padding: 20px;
                  font-size: 12px; color: #999; border-top: 1px solid #eee; }
    </style>
</head>
<body>
    <div class="header">
        <h2>C.G — Nouveau message de contact</h2>
    </div>
    <div class="content">

        <div class="field">
            <div class="label">Email expéditeur</div>
            <div class="value">{{ contact.email }}</div>
        </div>

        <div class="field">
            <div class="label">Sujet</div>
            <div class="value">{{ contact.subject }}</div>
        </div>

        <div class="field">
            <div class="label">Message</div>
            <div class="value">{{ contact.content }}</div>
        </div>

        <div class="field">
            <div class="label">Date d'envoi</div>
            <div class="value">{{ contact.createdAt|date('d/m/Y à H:i') }}</div>
        </div>

    </div>
    <div class="footer">
        Ce message a été envoyé depuis le formulaire de contact du site C.G
    </div>
</body>
</html>